{
  "compilerOptions": {
    "target": "es5",                          
    "module": "commonjs",                    
    "lib": ["es6", "DOM"],                     
    "allowJs": true,
    "outDir": "build",                          
    "rootDir": "src",
    "strict": true,         
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "baseUrl": "./",
    "paths": {
      "common/*": ["src/common/*"]
    },
  },
  "exclude": [
    "node_modules",
    "webpack.server.config.js",
    "webpack.client.config.js",
    "dist"
  ]
}